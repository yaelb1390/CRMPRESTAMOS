# ==========================================================================
# Variables de entorno — configúralas en Vercel (Project > Settings > Environment Variables)
# En local, copia este archivo a .env y rellena los valores reales.
# ==========================================================================

# --- Base de datos PostgreSQL (Supabase) ---
# En Vercel/serverless usa la cadena del POOLER de transacciones de Supabase
# (host ...pooler.supabase.com, puerto 6543) para no agotar conexiones.
DATABASE_URL=postgresql://usuario:password@host:6543/postgres

# --- Autenticación ---
# Genera un secreto fuerte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_ALEATORIO_DE_64_BYTES

# Secreto para el Cron de Vercel que recalcula la mora (/api/prestamos/actualizar-mora).
# Genera otro valor aleatorio. Vercel lo envía como "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=CAMBIA_ESTO_POR_OTRO_SECRET_ALEATORIO

# --- Correo (SMTP) para envío de facturas/recibos ---
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_password_smtp

# --- Integración n8n (notificaciones de WhatsApp) ---
N8N_WEBHOOK_URL=https://tu-instancia-n8n/webhook/xxxxx

# --- Entorno ---
# Vercel define NODE_ENV automáticamente; no hace falta configurarla allí.
NODE_ENV=production
